{
  "info": {
    "name": "User API",
    "description": "CRUD + Avatar upload for User endpoint",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "userId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Create User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/user",
          "host": ["{{baseUrl}}"],
          "path": ["user"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Ahmed\",\n  \"lastName\": \"Ghoneim\",\n  \"age\": 25,\n  \"email\": \"ahmed.ghoneim@example.com\",\n  \"password\": \"Str0ngP@ss\",\n  \"phone\": \"+201012345678\",\n  \"address\": \"Cairo, Egypt\"\n}"
        }
      }
    },
    {
      "name": "Get All Users",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/user",
          "host": ["{{baseUrl}}"],
          "path": ["user"]
        }
      }
    },
    {
      "name": "Get User By ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/user/{{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["user", "{{userId}}"]
        }
      }
    },
    {
      "name": "Update User",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/user/{{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["user", "{{userId}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Ahmed\",\n  \"lastName\": \"Mohamed\",\n  \"phone\": \"+201098765432\",\n  \"address\": \"Alexandria, Egypt\"\n}"
        }
      }
    },
    {
      "name": "Upload Avatar",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/user/{{userId}}/avatar",
          "host": ["{{baseUrl}}"],
          "path": ["user", "{{userId}}", "avatar"]
        },
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "avatar",
              "type": "file",
              "src": "/path/to/your-image.jpg",
              "description": "Select an image file (jpeg, png, gif, webp) under 5MB"
            }
          ]
        }
      }
    },
    {
      "name": "Delete User",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/user/{{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["user", "{{userId}}"]
        }
      }
    }
  ]
}
